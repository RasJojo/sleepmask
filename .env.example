# =============================================================
# SLEEPMASK PRO — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER .env
# =============================================================

# ── Unlink ──────────────────────────────────────────────────
# API key depuis https://hackaton-apikey.vercel.app
UNLINK_API_KEY=

# Clé privée EVM du relayer (0x...) — signe les txs on-chain (approve, deposit, withdraw)
# Doit avoir du ETH sur Base Sepolia pour le gas
EVM_PRIVATE_KEY=

# Mnemonic Unlink du user de test (12 mots BIP39)
# En prod, chaque user a le sien stocké en DB
USER_MNEMONIC=

# ── WalletConnect ────────────────────────────────────────────
WALLETCONNECT_PROJECT_ID=
WALLETCONNECT_PAY_ID=

# ── Dynamic ──────────────────────────────────────────────────
DYNAMIC_ENV_ID=

# ── Smart contract ──────────────────────────────────────────
# Rempli après deploy Hardhat
CONTRACT_ADDRESS=

# ── Chain ────────────────────────────────────────────────────
RPC_URL=https://sepolia.base.org

# ── Serveur ──────────────────────────────────────────────────
PORT=3000
